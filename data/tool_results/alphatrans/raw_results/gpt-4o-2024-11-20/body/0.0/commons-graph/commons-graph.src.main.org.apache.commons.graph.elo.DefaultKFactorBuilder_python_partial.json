                        "        switch (gameResult) {\n",
                        "            case WIN:\n",
                        "                sA = 1;\n",
                        "                sB = 0;\n",
                        "                break;\n",
                        "\n",
                        "            case DRAW:\n",
                        "                final double number = 0.5;\n",
                        "                sA = number;\n",
                        "                sB = number;\n",
                        "                break;\n",
                        "\n",
                        "            default: // should not happen\n",
                        "                throw new IllegalArgumentException(\"Input GameResult not accepted\");\n",
                        "        }\n",
                        "\n",
                        "        updateRanking(playerA, kFactor, sA, eA);\n",
