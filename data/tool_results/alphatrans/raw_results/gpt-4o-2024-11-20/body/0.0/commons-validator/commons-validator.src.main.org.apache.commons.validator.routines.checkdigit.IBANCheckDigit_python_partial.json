                        "                raise CheckDigitException.CheckDigitException1(",
                        "                    f\"Invalid Character[{i}] = '{char}'\"",
                        "                )",
                        "            total = (total * 100 if char_value > 9 else total * 10) + char_value",
                        "            if total > self.__MAX:",
                        "                total %= self.__MODULUS",
                        "        return total % self.__MODULUS"
