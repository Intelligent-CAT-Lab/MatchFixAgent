                        "            fail(\"calculate() Lth 11 - expected exception\");\n",
                        "        } catch (Exception e) {\n",
                        "            assertEquals(\"calculate() Lth 11\", \"Invalid ISBN Length = 11\", e.getMessage());\n",
                        "        }\n",
                        "        try {\n",
                        "            routine.calculate(\"1234567890123\");\n",
