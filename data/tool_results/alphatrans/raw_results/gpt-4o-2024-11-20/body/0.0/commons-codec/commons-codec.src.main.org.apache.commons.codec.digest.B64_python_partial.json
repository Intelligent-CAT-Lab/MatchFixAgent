                        "    static void b64from24bit(\n",
                        "            final byte b2,\n",
                        "            final byte b1,\n",
                        "            final byte b0,\n",
                        "            final int outLen,\n",
                        "            final StringBuilder buffer) {\n",
                        "        int w = ((b2 << 16) & 0x00ffffff) | ((b1 << 8) & 0x00ffff) | (b0 & 0xff);\n",
                        "        int n = outLen;\n",
                        "        while (n-- > 0) {\n",
                        "            buffer.append(B64T_ARRAY[w & 0x3f]);\n",
                        "            w >>= 6;\n",
                        "        }\n",
                        "    }\n"
