                        "  // https://stackoverflow.com/questions/7031198/java-signed-long-to-unsigned-long-string\n",
                        "  static String toUnsignedString(long l) {\n",
                        "    BigInteger b = BigInteger.valueOf(l);\n",
                        "    if (b.signum() < 0) {\n",
                        "      b = b.add(TWO_64);\n",
                        "    }\n",
                        "    return b.toString();\n",
                        "  }\n"
