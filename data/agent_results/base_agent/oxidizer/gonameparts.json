            "func (n *nameString) splitAliases(aliasSep string) {",
            "    splitNames := n.split()",
            "",
            "    for index, part := range splitNames {",
            "        if strings.ToUpper(part) == aliasSep {",
            "            splitNames[index] = \"*|*\"",
            "        }",
            "    }",
            "",
            "    names := strings.Split(strings.Join(splitNames, \" \"), \"*|*\")",
            "    n.FullName = names[0]",
            "    n.Aliases = names[1:]",
            "}"
        ],
        "target_function": [
            "impl NameString {",
            "    pub(crate) fn split_aliases(&mut self, alias_sep: &str) -> Result<(), Error> {",
            "        let split_names: Vec<_> = self.split().iter().cloned().collect();",
            "",
            "        let transformed_names: Vec<_> = split_names",
            "            .iter()",
            "            .map(|part| {",
            "                if part.to_uppercase() == alias_sep.to_uppercase() {",
            "                    \"*|*\".to_string()",
            "                } else {",
            "                    part.clone()",
            "                }",
            "            })",
            "            .collect();",
            "",
            "        let names: Vec<_> = str::replace(&transformed_names.join(\" \"), \"*|*\", \"\")",
            "            .split('*')",
            "            .filter(|s| !s.is_empty())",
            "            .map(str::to_string)",
            "            .collect();",
            "",
            "        self.full_name = names[0].clone();",
            "        self.aliases = names[1..].to_vec();",
            "",
            "        Ok(())",
            "    }",
            "}"
        ],
