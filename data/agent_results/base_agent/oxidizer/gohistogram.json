        "source_function": [
            "func (h *NumericHistogram) Add(n float64) {",
            "    defer h.trim()",
            "    h.total++",
            "    for i := range h.bins {",
            "        if h.bins[i].value == n {",
            "            h.bins[i].count++",
            "            return",
            "        }",
            "",
            "        if h.bins[i].value > n {",
            "",
            "            newbin := bin{value: n, count: 1}",
            "            head := append(make([]bin, 0), h.bins[0:i]...)",
            "",
            "            head = append(head, newbin)",
            "            tail := h.bins[i:]",
            "            h.bins = append(head, tail...)",
            "            return",
            "        }",
            "    }",
            "",
            "    h.bins = append(h.bins, bin{count: 1, value: n})",
            "}"
        ],
        "target_function": [
            "impl __Synth0__add for NumericHistogram {",
            "    fn add(&mut self, n: f64) {",
            "        self.trim().unwrap();",
            "        self.total += 1;",
            "        for i in 0..self.bins.len() {",
            "            if self.bins[i].value == n {",
            "                self.bins[i].count += 1.0;",
            "                return;",
            "            }",
            "",
            "            if self.bins[i].value > n {",
            "                let newbin = Bin { value: n, count: 1.0 };",
            "                let mut head = VecDeque::from_iter(self.bins.iter().take(i).cloned());",
            "                head.push_back(newbin);",
            "                let tail = self.bins.split_off(i);",
            "                self.bins = head.into_iter().chain(tail.into_iter()).collect();",
            "                return;",
            "            }",
            "        }",
            "",
            "        self.bins.push_back(Bin { count: 1.0, value: n });",
            "    }",
            "}"
        ],
