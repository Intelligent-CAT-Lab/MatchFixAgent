            "    if h.total == 0 {",
            "        return 0",
            "    }",
            "",
            "    sum := 0.0",
            "    mean := h.Mean()",
            "",
            "    for i := range h.bins {",
            "        sum += (h.bins[i].count * (h.bins[i].value - mean) * (h.bins[i].value - mean))",
            "    }",
            "",
            "    return sum / h.total",
            "}"
